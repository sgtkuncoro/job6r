# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# The ai-assist scripts auto-load .env (searching up from the script directory),
# so you don't need to `export` anything in your shell.

# Required: your Groq API key (free at https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# Optional: override the model. Default is llama-3.3-70b-versatile.
# Other good choices: openai/gpt-oss-120b, moonshotai/kimi-k2-instruct, qwen/qwen3-32b
# See https://console.groq.com/docs/models
# MODEL=openai/gpt-oss-120b
